# Copy to .env for local development (docker compose --env-file .env, or
# `set -a; source .env; set +a` before running uvicorn directly).

TZ=Europe/Amsterdam
DEFAULT_LANGUAGE=nl

AUTH_ENABLED=true
APP_PASSWORD=changeme
SESSION_SECRET=changeme-to-a-long-random-string
PRINT_API_TOKEN=changeme-bearer-token

# "file" for the real printer, "dummy" for local development without hardware
PRINTER_BACKEND=dummy
PRINTER_DEVICE=/dev/usb/lp0

DATA_DIR=./data
